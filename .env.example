# Internet Health & Status Engine — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

# ── TimescaleDB ──────────────────────────────
TIMESCALE_DB=inethealth
TIMESCALE_USER=inetuser
TIMESCALE_PASSWORD=changeme_timescale

# ── Neo4j ────────────────────────────────────
NEO4J_AUTH=neo4j/changeme_neo4j

# ── MinIO ────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_minio

# ── API Keys (add real values in .env) ───────
CLOUDFLARE_RADAR_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=

# ── Collector tuning ─────────────────────────
POLL_INTERVAL=300
BGP_COLLECTORS=ripe-ris,routeviews
RIPE_RIS_COLLECTORS=rrc00,rrc01,rrc03,rrc04,rrc05
